# .env.example
#
# Copy this to .env.local for local development. On Vercel, add these same
# keys under Project Settings -> Environment Variables instead of committing
# a real .env file.

# --- Database (Postgres + PostGIS) ------------------------------------------
# Works with Supabase, Neon, or any Postgres with the postgis extension
# enabled. If using Supabase, use the "Connection pooling" URL (port 6543)
# for serverless — direct connections (port 5432) will exhaust your
# connection limit under Vercel's concurrent function model.
DATABASE_URL="postgresql://user:password@host:6543/postgres"

# --- Auth --------------------------------------------------------------
# Generate with: openssl rand -base64 32
SESSION_JWT_SECRET="REPLACE_ME_WITH_A_RANDOM_32_BYTE_SECRET"

# --- App ---------------------------------------------------------------
# REQUIRED in production: Set to your real Vercel deployment URL.
# Used to build payment redirect URLs. Without this, payment callbacks will
# redirect to localhost and fail silently.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# REQUIRED in production: The UUID of the infrastructure owner account.
# Contractors use this to submit zone checks against the right owner's baseline.
# Create the owner account first, then set this to that user's UUID.
NEXT_PUBLIC_OWNER_ID="REPLACE_ME_WITH_OWNER_UUID"

# --- GDAL WASM (client-side GIS parsing) --------------------------------
# Leave unset to load gdal3.js's wasm/data files from jsDelivr's CDN
# (default). Set to "/gdal3wasm" only if you've run `npm run gdal:vendor`
# to self-host those files instead (see scripts/copy-gdal-wasm.js).
# NEXT_PUBLIC_GDAL_WASM_PATH="/gdal3wasm"

# --- FOMO Pay ------------------------------------------------------------
# IMPORTANT: these field names and the base URL are placeholders pending
# confirmation against FOMO Pay's actual Web Payment API document (download
# from https://developers.fomopay.com after registering as a merchant).
# See lib/payments/fomoPay.ts for every place marked "// TODO: confirm".
FOMO_PAY_API_BASE="https://api.fomopay.com"
FOMO_PAY_MERCHANT_ID="REPLACE_ME"
FOMO_PAY_API_KEY="REPLACE_ME"
FOMO_PAY_WEBHOOK_SECRET="REPLACE_ME"
